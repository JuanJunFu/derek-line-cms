generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  counties  String[]
  order     Int
  isActive  Boolean  @default(true)
  stores    Store[]
  createdAt DateTime @default(now())
}

model Store {
  id           String    @id @default(cuid())
  name         String
  type         StoreType
  regionId     String
  region       Region    @relation(fields: [regionId], references: [id])
  address      String
  phone        String
  fax          String?
  lineId       String?
  hours        String
  imageUrl     String?
  googleMapUrl String?
  latitude     Float?
  longitude    Float?
  description  String?
  isActive     Boolean   @default(true)
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum StoreType {
  FLAGSHIP
  BRANCH
  DEALER
  GENERAL
}

model AutoReply {
  id       String  @id @default(cuid())
  keyword  String?
  message  String
  isActive Boolean @default(true)
  order    Int     @default(0)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model SiteSetting {
  key       String @id
  value     String
  label     String
  updatedAt DateTime @updatedAt
}

// ── Product Catalog ──

model ProductCategory {
  id              String              @id @default(cuid())
  slug            String              @unique  // e.g. "toilet", "faucet"
  name            String                       // 馬桶
  emoji           String              @default("")  // 🚽
  intent          String              @default("")  // Comfort_High (for tracking)
  url             String              @default("")  // Official site link
  order           Int                 @default(0)
  isActive        Boolean             @default(true)
  subcategories   ProductSubcategory[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ProductSubcategory {
  id              String          @id @default(cuid())
  categoryId      String
  category        ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug            String          // e.g. "toilet_smart"
  name            String          // 智慧馬桶
  url             String          @default("")  // Link to product page
  order           Int             @default(0)
  createdAt       DateTime        @default(now())

  @@index([categoryId])
}

// ── Intent Tracking ──

model UserEvent {
  id             String   @id @default(cuid())
  webhookEventId String?  @unique
  userId         String
  eventType      String   // FOLLOW, UNFOLLOW, MESSAGE, REGION_SELECT, STORE_VIEW, STORE_CALL, STORE_NAV, STORE_LINE, PRODUCT_VIEW, FALLBACK
  category       String?
  region         String?
  storeId        String?
  data           Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@index([category])
  @@index([region])
  @@index([storeId])
}

model UserProfile {
  userId              String   @id
  displayName         String?
  tags                String[]
  leadScore           String   @default("COLD")
  hotSince            DateTime?
  lastActive          DateTime @default(now())
  firstSeen           DateTime @default(now())
  totalEvents         Int      @default(0)
  isBlocked           Boolean  @default(false)
  // ── Dual-track scoring (Phase 1) ──
  relationshipScore   Int      @default(0)   // 0-100 長期關係分
  relationshipLevel   String   @default("新識")
  customerType        String   @default("new") // "new" | "returning" — 唯一真相來源
  // sequenceState: { "new_customer": { "currentStep": 1, "startedAt": "...", "completedAt": null } }
  sequenceState       Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([leadScore])
  @@index([lastActive])
  @@index([isBlocked])
  @@index([relationshipScore])
  @@index([customerType])
}

// ── Automated Sequences ──

model Sequence {
  id          String         @id @default(cuid())
  name        String
  trigger     String         // new_customer | repair_inquiry | product_view_smart
  steps       SequenceStep[]
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model SequenceStep {
  id          String    @id @default(cuid())
  sequenceId  String
  sequence    Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  dayOffset   Int       // Day 0, 3, 7, 30
  messageType String    // "flex" | "text"
  content     Json      // Flex Message JSON or { text: "..." }; Flex 必須含 Postback action
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([sequenceId])
}

model ScheduledMessage {
  id          String    @id @default(cuid())
  userId      String
  sequenceId  String
  stepId      String
  scheduledAt DateTime
  sentAt      DateTime?
  // ⚠️ 冪等保護：scheduler 以 atomic UPDATE WHERE status='pending' 取任務
  status      String    @default("pending") // pending | processing | sent | cancelled
  createdAt   DateTime  @default(now())

  @@index([scheduledAt, status])
  @@index([userId])
}

// ── Alert System ──

model AlertRule {
  id          String   @id @default(cuid())
  name        String                          // e.g. "用戶升級為 HOT"
  eventType   String                          // LEAD_HOT, FALLBACK_3X, STORE_REPEAT, NEW_FOLLOW
  threshold   Int      @default(1)            // 觸發次數
  windowMin   Int      @default(0)            // 時間窗口(分鐘), 0=即時
  isActive    Boolean  @default(true)
  notifyLine  Boolean  @default(true)         // 是否 LINE 推播
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        AlertLog[]
}

model AlertLog {
  id          String    @id @default(cuid())
  ruleId      String
  rule        AlertRule @relation(fields: [ruleId], references: [id])
  userId      String                           // LINE user ID
  userName    String?                           // 用戶顯示名稱
  storeId     String?
  storeName   String?
  regionName  String?
  message     String                            // 通知內容
  tags        String[]                          // 快照用戶標籤
  isRead      Boolean  @default(false)
  lineNotified Boolean @default(false)          // LINE 是否已推播
  createdAt   DateTime @default(now())

  @@index([ruleId])
  @@index([isRead])
  @@index([createdAt])
}
